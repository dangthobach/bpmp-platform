# ============================================================
# AuthZ Platform — Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# -- Database --
DATABASE_URL=postgres://authz:authz_secret@localhost:5432/authz_db
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DATABASE_ACQUIRE_TIMEOUT_SECS=10
DATABASE_IDLE_TIMEOUT_SECS=300

# -- Server --
HOST=0.0.0.0
PORT=8080
GRPC_PORT=50051
SERVER_REQUEST_TIMEOUT_SECS=30

# -- JWT --
# OpenID Connect JWKS endpoint used to verify service/user bearer tokens.
JWT_JWKS_URL=https://your-keycloak.example.com/realms/enterprise/protocol/openid-connect/certs
JWT_AUDIENCE=authz-platform

# -- Observability --
RUST_LOG=info,authz_server=debug,authz_engine=debug
OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_LISTEN_ADDR=0.0.0.0:9090

# -- Policy Engine --
# fail-open (ALLOW) or fail-closed (DENY) when policy bundle unavailable
FAIL_MODE=DENY
# Maximum ReBAC graph traversal depth
REBAC_MAX_DEPTH=10
# Maximum terms in ES/Mongo filter injected from ReBAC
REBAC_MAX_TERMS_FILTER_SIZE=1000

# -- Cache --
# Compiled predicate cache max entries
POLICY_CACHE_MAX_ENTRIES=10000
# User context cache TTL seconds
USER_CONTEXT_CACHE_TTL_SECS=300
# JIT attribute cache TTL seconds
JIT_ATTR_CACHE_TTL_SECS=30

# -- Rate limiting --
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=200

# -- Emergency revoke --
EMERGENCY_REVOKE_TTL_SECS=86400
